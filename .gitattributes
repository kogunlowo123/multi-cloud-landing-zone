# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Terraform files
*.tf text diff=terraform
*.tfvars text
*.tfstate text

# Documents
*.md text diff=markdown
*.txt text
*.csv text
*.json text
*.xml text
*.yaml text
*.yml text

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.gz binary
*.tar binary

# Terraform lock file
.terraform.lock.hcl text -diff
